# Kamera-Viewer Konfiguration - Beispiel
# ========================================
# Diese Datei wird vom setup.sh automatisch erstellt.
# Manuelle Bearbeitung nur wenn nötig.

display:
  # Auflösung des Monitors (leer = Auto)
  resolution: ""
  # "landscape" (Querformat) oder "portrait" (Hochformat)
  orientation: "landscape"
  # Drehung des Bildes in Grad: 0, 90, 180 oder 270
  rotation: 0
  # Hintergrundfarbe
  background: "#000000"

# Globale Standardwerte (können pro Kamera überschrieben werden)
defaults:
  port: 554
  
  # RTSP-Pfade für gängige Hersteller:
  # AXIS:              /axis-media/media.amp
  # Burgwächter/Dahua: /cam/realmonitor?channel=1&subtype=0
  # Hikvision:         /Streaming/Channels/101
  # ONVIF generisch:   /stream1
  rtsp_path: "/axis-media/media.amp"
  
  # Transport: "tcp" (stabil) oder "udp" (weniger Latenz)
  transport: "tcp"
  
  buffer_ms: 500

# Kamera-Liste
cameras:
  - name: "Eingang"
    ip: "192.168.1.100"
    username: "admin"
    password: "passwort123"
    
  - name: "Halle"
    ip: "192.168.1.101"
    username: "admin"
    password: "passwort123"

# Beispiel ohne Authentifizierung:
#  - name: "Öffentliche Kamera"
#    ip: "192.168.1.110"
#    username: ""
#    password: ""

# Beispiel mit eigenem RTSP-Pfad:
#  - name: "Hikvision-Kamera"
#    ip: "192.168.1.120"
#    username: "admin"
#    password: "passwort123"
#    rtsp_path: "/Streaming/Channels/101"
